{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.7.1",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "__MSG_extName__"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://pro.x.com/*"],
      "js": ["bridge.js", "src/premium/license/tier-logic.js", "src/premium/license/entitlement.js", "src/premium/license/isolated.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://x.com/*", "https://pro.x.com/*"],
      "js": ["lib/x-net-hook.js", "lib/x-client-transaction.js", "lib/grok-reply.js", "lib/long-image-viewer.js", "lib/image-viewer.js", "src/premium/license/gate.js", "src/premium/rate-filter/filter.js", "content.js", "starchart.js"],
      "css": ["styles.css"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
